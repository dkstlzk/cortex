# ---------------------------------------------------------------------------
# CORTEX Frontend — environment configuration
#
# Copy this file to `.env` and adjust the values for your environment:
#   cp .env.example .env
#
# All variables are read through `lib/config.ts`. Nothing here is hardcoded in
# application source. Only `NEXT_PUBLIC_*` variables are exposed to the browser
# (they are inlined into the client bundle at build time), so never put secrets
# in this file.
# ---------------------------------------------------------------------------

# Base URL of the CORTEX backend API (no trailing slash).
#   Local development:  http://localhost:8000
#   Staging/production: https://api.cortex.your-domain.com
# REQUIRED — the build fails fast if this is unset.
NEXT_PUBLIC_API_URL=https://api.cortex.example.com

# Versioned API path prefix. Must match the backend's API_V1_PREFIX.
NEXT_PUBLIC_API_PREFIX=/api/v1

# Product name rendered in the UI shell.
NEXT_PUBLIC_APP_NAME=CORTEX

# Entity tag the knowledge-graph landing view centres on by default.
NEXT_PUBLIC_DEFAULT_ENTITY=P-101A

# Default knowledge-graph traversal depth (hops from the centre node).
NEXT_PUBLIC_DEFAULT_GRAPH_DEPTH=2

# Maximum upload size in megabytes (should mirror the backend limit).
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# Timeout (in milliseconds) for non-streaming API requests.
NEXT_PUBLIC_REQUEST_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# CORTEX Backend — environment configuration template
#
# Copy this file to `.env` and fill in real values:
#   cd backend && cp .env.example .env
#
# Loaded by backend/shared/config.py (pydantic-settings), which resolves the
# file next to the backend package regardless of the working directory. Every
# backend LLM/infra client reads from this single source — never hardcode
# credentials or hosts in source.
# ---------------------------------------------------------------------------

# --- LLM (OpenAI-compatible endpoint) ---------------------------------------
# Works with any OpenAI-compatible provider. Examples:
#   Fireworks: LLM_BASE_URL=https://api.fireworks.ai/inference/v1
#              LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
#   OpenAI:    leave LLM_BASE_URL empty, LLM_MODEL=gpt-4o-mini
#
# LLM_API_KEY is the primary credential. FAST_MODEL_API_KEY is used by the P2
# retrieval query classifier; if left blank it falls back to LLM_API_KEY.
LLM_API_KEY=your-llm-api-key
FAST_MODEL_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60.0
LLM_MAX_RETRIES=3

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cortex

# --- Neo4j ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Qdrant -----------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortex_chunks

# --- Redis / RQ -------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Embeddings (local FastEmbed) -------------------------------------------
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# --- App --------------------------------------------------------------------
DEBUG=false
